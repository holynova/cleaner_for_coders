{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dev Space Cleaner",
  "version": "0.1.0",
  "identifier": "com.sym.dev-space-cleaner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dev Space Cleaner",
        "width": 1240,
        "height": 900,
        "minWidth": 1240,
        "maxWidth": 1240,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
